# Copy to .env and fill in. All values below work with docker-compose defaults.

NODE_ENV=development
PORT=3000

# PostgreSQL (pgvector/pgvector:pg16 container — host port 5433 to avoid clashing with a
# native Postgres install on 5432)
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
DATABASE_URL=postgres://rag:rag@localhost:5433/rag

# Redis (redis:7-alpine container — host port 6380 to avoid clashing with other projects)
REDIS_URL=redis://localhost:6380

# OpenAI — needed from Phase 5 (embeddings + answers)
OPENAI_API_KEY=
